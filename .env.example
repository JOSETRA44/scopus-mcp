# Required: Elsevier Scopus API key
# Obtain at: https://dev.elsevier.com/
SCOPUS_API_KEY=your_api_key_here

# Optional: Institutional token for off-campus / full-text access
# Obtain from your institution's Elsevier account manager
SCOPUS_INST_TOKEN=

# Optional: Response cache TTL in seconds (default: 300 = 5 minutes)
SCOPUS_CACHE_TTL=300

# Optional: Max retries on 429 rate-limit errors (default: 3)
SCOPUS_MAX_RETRIES=3

# Optional: Logging verbosity (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
